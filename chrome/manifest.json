{
  "update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "ÖTEK Currency Converter",
  "version": "2.0.1",
  "author": "Ömer Kadir",
  "description": "Convert currencies using xe.otek.today API",
  "homepage_url": "https://omertek.com/",
  "permissions": ["storage", "contextMenus", "tabs", "scripting"],
  "host_permissions": [
    "https://xe.otek.today/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "favicon.png"
    },
    "default_popup": "popup.html",
    "default_title": "ÖTEK Currency Converter"
  },
  "options_page": "options.html",
  "options_ui": {
    "open_in_tab": true,
    "page": "options.html"
  },
  "icons": {
    "48": "favicon.png"
  }
}