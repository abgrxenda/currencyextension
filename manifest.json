{
  "manifest_version": 2,
  "name": "ÖTEK Currency Converter",
  "version": "1.9.5",
  "author": "Ömer Kadir",
  "description": "Convert currencies using xe.otek.today API",
  "homepage_url": "https://omertek.com/",
  "content_security_policy": "script-src 'self'; object-src 'none'; connect-src http://xe.otek.today/",
  "browser_specific_settings": {
    "gecko": {
      "id": "otek.converter@otek.today",
      "update_url": "https://omertek.com/currencyextensionupdate/currencyextensionupdate.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "favicon.png"
  },
  "browser_action": {
    "default_icon": {
      "48": "favicon.png"
    },
    "default_title": "ÖTEK Currency Converter",
    "default_popup": "options.html"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "http://xe.otek.today/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html"
  },
  "web_accessible_resources": [
    "popup.html",
    "popup.js"
  ]
}