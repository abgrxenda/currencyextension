{
  "manifest_version": 2,
  "name": "ÖTEK Currency Converter",
  "version": "2.0.1",
  "author": "Ömer Kadir",
  "description": "Convert currencies using xe.otek.today API",
  "homepage_url": "https://omertek.com/",
  "content_security_policy": "script-src 'self'; object-src 'none'; connect-src http://xe.otek.today/",

  "browser_specific_settings": {
    "gecko": {
      "id": "otek.converter@otek.today",
      "data_collection_permissions": { "required": ["none"] },
      "strict_min_version": "140.0"
    }
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {"default": "Alt+Shift+T"},
      "description": "Open pop-up window."
    }
  },
  
  "icons": {
    "48": "favicon.png"
  },

  "browser_action": {
    "default_icon": { "48": "favicon.png" },
    "default_title": "ÖTEK Currency Converter",
    "default_popup": "popup.html"
  },

  "options_ui": {
    "page": "options.html"
  },

  "permissions": [
    "menus",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "http://xe.otek.today/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "web_accessible_resources": [
    "popup.html",
    "popup.js"
  ]
}