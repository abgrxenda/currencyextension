{
  "manifest_version": 2,
  "name": "ÖTEK Currency Converter",
  "version": "1.2.3",
  "author": "Ömer Kadir",
  "description": "Convert currencies using xe.otek.today API",
  "homepage_url": "https://omertek.com/",
  "content_security_policy": "script-src 'self'; object-src 'none'",
  "browser_specific_settings": {
    "gecko": {
      "id": "otek.converter@otek.today"
    }
  },
  "icons": {
    "48": "favicon.png"
  },
  "browser_action": {
    "default_icon": {
      "48": "favicon.png"
    },
    "default_title": "ÖTEK Currency Converter",
    "default_popup": "options.html"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html"
  }

}
